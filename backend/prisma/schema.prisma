generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String
  firstName       String
  lastName        String
  schoolGrade     Int
  city            String?
  hobbies         String?
  achievements    String?
  characteristic  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  grades          Grade[]
  examScores      ExamScore[]
  careerProfile   CareerProfile?
  chatHistory     ChatMessage[]

  @@map("users")
}

model Grade {
  id        String   @id @default(uuid())
  userId    String
  subject   String
  quarter1  Float?
  quarter2  Float?
  quarter3  Float?
  quarter4  Float?
  yearScore Float?
  examScore String?
  finalScore Float?
  year      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subject, year])
  @@map("grades")
}

model ExamScore {
  id        String   @id @default(uuid())
  userId    String
  examType  String
  subject   String
  score     Int
  year      Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("exam_scores")
}

model CareerProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  desiredSphere     String?
  desiredUniversity String?
  cri               Float?
  criBreakdown      Json?
  trackerPlan       Json?
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("career_profiles")
}

model Institution {
  id          String  @id @default(uuid())
  name        String
  city        String
  faculties   Json
  entryScores Json
  isActive    Boolean @default(true)

  @@map("institutions")
}

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model KnowledgeChunk {
  id        String   @id @default(uuid())
  content   String   @db.Text
  source    String
  category  String
  createdAt DateTime @default(now())

  @@map("knowledge_chunks")
}
